Assembly     nfd
Type         static_library
Version      1.3.0
Description  nativefiledialog-extended, native OS file picker for the Replay open dialog

# fetch the pinned release on first build
if !nfd/
{
    PreDepend.Cmd git clone --depth 1 --branch v1.3.0 https://github.com/btzy/nativefiledialog-extended.git nfd
}

SourceDirectory       nfd/src
BuildDirectory        Build
IntermediateDirectory Intermediate/nfd

Compiler.Includes        nfd/src/include
Compiler.Includes.Export nfd/src/include

if windows
{
    SourceFiles nfd_win.cpp
    Libraries.Export ole32 uuid shell32
}

if apple
{
    SourceFiles nfd_cocoa.m
    Frameworks  AppKit UniformTypeIdentifiers
}

if linux
{
    # the portal backend talks to the desktop file chooser over dbus (needs libdbus-1-dev);
    # paths below match `pkg-config --cflags dbus-1` on debian/ubuntu x64
    SourceFiles nfd_portal.cpp
    Compiler.Includes /usr/include/dbus-1.0 /usr/lib/x86_64-linux-gnu/dbus-1.0/include
    Libraries.Export dbus-1
}

if msvc
{
    Compiler.Flags /std:c++20 /EHsc
}

if clang|gcc
{
    Compiler.Flags -std=c++20
}
